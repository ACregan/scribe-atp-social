# Required: 32+ random chars — signs session and pending cookies
SESSION_SECRET=

# Required in production: base URL of this service
# PUBLIC_URL=https://social.scribe-atp.app

# Optional: port to listen on (default: 3010)
# PORT=3011

# Set to "production" to enable real AT Protocol OAuth
# NODE_ENV=production

# Required for POST /notify — subscriber DM notifications
# Generate a strong random string and share it with scribe-atp.app (NOTIFY_SECRET)
NOTIFY_SECRET=

# Bluesky author account used to send subscriber DMs
# Create an app password at bsky.app → Settings → App Passwords
AUTHOR_HANDLE=
AUTHOR_APP_PASSWORD=
